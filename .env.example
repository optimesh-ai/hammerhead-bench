# Copy to .env and edit. The harness reads both this and the shell environment.
#
# Required:
# Path to the Hammerhead CLI. The harness invokes this as a black box:
#   $HAMMERHEAD_CLI simulate <configs_dir> --format json
#
# For development before phase 6, point at the fake script which returns a
# perturbed copy of the vendor truth FIB so the pipeline has a non-empty diff
# to surface.
HAMMERHEAD_CLI=./scripts/fake_hammerhead.sh

# Optional overrides. Defaults come from versions.lock; set these only if you
# want to run one-off against a different image without editing the lockfile.
# FRR_IMAGE=frrouting/frr:10.2.1
# BATFISH_IMAGE=batfish/allinone@sha256:...
# CEOS_IMAGE=ceos:4.32.0F

# Soft cap on topology node count. Set to skip large topologies when running
# `make bench`. Unset = no cap.
# MAX_NODES=6

# Optional knob for the memory guard: override the required headroom multiplier
# (default 2.0 means "host must have 2x the sum of container caps free").
# MEMORY_HEADROOM_MULTIPLIER=2.0
