frr defaults traditional
hostname {{ node.name }}
no ipv6 forwarding
!
{% if params.role == "pe" -%}
vrf RED
 vni 100
exit-vrf
!
{% endif -%}
interface lo
 ip address {{ params.loopback }}/32
 ip ospf area 0.0.0.0
!
{% for iface in node.interfaces %}
{%- if params.role == "pe" and iface.name == "eth2" %}
interface {{ iface.name }} vrf RED
{%- else %}
interface {{ iface.name }}
{%- endif %}
{%- if iface.description %}
 description {{ iface.description }}
{%- endif %}
{%- if iface.ip %}
 ip address {{ iface.ip }}
{%- endif %}
{%- if not (params.role == "pe" and iface.name == "eth2") %}
 ip ospf area 0.0.0.0
 mpls enable
{%- endif %}
!
{% endfor %}
router ospf
 ospf router-id {{ params.loopback }}
 passive-interface lo
!
mpls ldp
 router-id {{ params.loopback }}
 !
 address-family ipv4
  discovery transport-address {{ params.loopback }}
 exit-address-family
!
{% if params.role == "pe" -%}
router bgp {{ params.asn }}
 bgp router-id {{ params.loopback }}
 no bgp ebgp-requires-policy
 neighbor {{ params.peer_loopback }} remote-as {{ params.asn }}
 neighbor {{ params.peer_loopback }} update-source lo
 !
 address-family ipv4 vpn
  neighbor {{ params.peer_loopback }} activate
 exit-address-family
!
router bgp {{ params.asn }} vrf RED
 no bgp ebgp-requires-policy
 !
 address-family ipv4 unicast
  network {{ params.site_prefix }}
  rd vpn export {{ params.rd }}
  rt vpn both {{ params.rt }}
  export vpn
  import vpn
 exit-address-family
!
{% endif -%}
line vty
!
